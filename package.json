{
  "name": "brotia",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @brotia/web dev",
    "dev:mobile": "pnpm --filter @brotia/mobile start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "patchedDependencies": {
      "@react-navigation/bottom-tabs@7.15.10": "patches/@react-navigation__bottom-tabs@7.15.10.patch"
    }
  }
}
